{
  "dataRoles": [
    {
      "displayName": "Field",
      "name": "field",
      "kind": "Grouping",
      "description": "Up to 5 columns. Each column with exactly 2 distinct values produces its own toggle. Fields must be from the same table or related tables (Power BI requires a relationship to evaluate multiple bound columns in a single visual)."
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "field": { "max": 5 } }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "field" },
          "dataReductionAlgorithm": { "top": { "count": 10 } }
        }
      }
    }
  ],
