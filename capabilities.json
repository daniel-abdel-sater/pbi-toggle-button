{
  "dataRoles": [
    {
      "displayName": "Field",
      "name": "field",
      "kind": "Grouping",
      "description": "Up to 5 columns. Each column produces its own toggle — one segment per distinct value (Power BI's data reduction caps the count at top 10 by default). Fields must be from the same table or related tables (Power BI requires a relationship to evaluate multiple bound columns in a single visual)."
    },
    {
      "displayName": "Default Selection (optional)",
      "name": "defaultValue",
      "kind": "Measure",
      "description": "Optional. Bind one DAX measure per Field, in the same field-well order. Return 1 for the value that should be the default selection, and 0 for everything else. IMPORTANT: ALWAYS RETURN 0 (NEVER BLANK) for non-default rows — Power BI silently drops cross-product rows where every bound measure returns BLANK, which prunes the toggle's other value out of the data view and breaks the A/B layout. Example: SWITCH(TRUE(), SELECTEDVALUE(table[col]) = \"value1\", 1, 0) — note the trailing 0 fallback. Only applies on first bind / fresh report — once the user clicks, their choice wins until the field is rebound."
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "field": { "max": 5 }, "defaultValue": { "max": 5 } }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "field" },
          "dataReductionAlgorithm": { "top": { "count": 30000 } }
        },
        "values": {
          "for": { "in": "defaultValue" }
        }
      }
    }
  ],
