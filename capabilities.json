{
  "dataRoles": [
    {
      "displayName": "Field",
      "name": "field",
      "kind": "Grouping",
      "description": "A column with exactly 2 distinct values. The toggle will switch between them."
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "field": { "max": 1 } }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "field" },
          "dataReductionAlgorithm": { "top": { "count": 10 } }
        }
      }
    }
  ],
  "objects": {
    "general": {
      "displayName": "Toggle",
      "properties": {
        "showTitle":           { "displayName": "Show Title",                "type": { "bool": true } },
        "titleText":           { "displayName": "Title Text",                "type": { "text": true } },
        "titlePosition":       { "displayName": "Title Position",            "type": { "text": true } },
        "titleColor":          { "displayName": "Title Color",               "type": { "fill": { "solid": { "color": true } } } },
        "titleFontSize":       { "displayName": "Title Font Size",           "type": { "numeric": true } },

        "sizeMode":            { "displayName": "Size Mode",                 "type": { "text": true } },
        "size":                { "displayName": "Fixed Size (px)",           "type": { "numeric": true } },
        "cornerRadius":        { "displayName": "Track Radius",              "type": { "numeric": true } },
        "thumbPadding":        { "displayName": "Track Padding (px)",        "type": { "numeric": true } },

        "showSymbols":         { "displayName": "Show Symbols",              "type": { "bool": true } },
        "symbolA":             { "displayName": "Symbol A",                  "type": { "text": true } },
        "symbolB":             { "displayName": "Symbol B",                  "type": { "text": true } },
        "showLabels":          { "displayName": "Show Labels",               "type": { "bool": true } },

        "trackBgTopAlpha":     { "displayName": "Track Top α (×1000)",    "type": { "numeric": true } },
        "trackBgBotAlpha":     { "displayName": "Track Bottom α (×1000)", "type": { "numeric": true } },
        "trackBorderAlpha":    { "displayName": "Track Border α (×1000)", "type": { "numeric": true } },

        "thumbGlowColor":      { "displayName": "Accent Color",              "type": { "fill": { "solid": { "color": true } } } },
        "thumbRingAlpha":      { "displayName": "Ring α (×100)",         "type": { "numeric": true } },
        "thumbBloomAlpha":     { "displayName": "Bloom α (×100)",        "type": { "numeric": true } },
        "thumbGlowSpread":     { "displayName": "Bloom Spread (px)",         "type": { "numeric": true } },
        "thumbHighlightAlpha": { "displayName": "Inner Highlight α (×100)", "type": { "numeric": true } },

        "labelActiveColor":    { "displayName": "Label Color (Active)",      "type": { "fill": { "solid": { "color": true } } } },
        "labelInactiveColor":  { "displayName": "Label Color (Inactive)",    "type": { "fill": { "solid": { "color": true } } } },
        "symbolInactiveAlpha": { "displayName": "Inactive Symbol α (×100)", "type": { "numeric": true } },

        "transitionDuration":  { "displayName": "Transition Duration (ms)",  "type": { "numeric": true } },
        "transitionEase":      { "displayName": "Transition Easing",         "type": { "text": true } }
      }
    },
    "toolbar": {
      "displayName": "Runtime State",
      "properties": {
        "selectedValue": { "displayName": "Selected Value", "type": { "text": true } }
      }
    }
  },
  "privileges": [],
  "supportsKeyboardFocus": true,
  "supportsLandingPage": true
}
